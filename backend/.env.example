# Railway usually provides this automatically when Postgres is attached.
# Prefer DATABASE_URL in production and use the DB_* values only for local fallback.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional local fallback when DATABASE_URL is not set
DB_NAME=inventory
DB_USER=inventory_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Django Configuration
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.railway.app

# Frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
